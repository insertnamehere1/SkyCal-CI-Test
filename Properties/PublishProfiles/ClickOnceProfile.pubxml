<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>ClickOnce</PublishProtocol>
    <Configuration>Release</Configuration>

    <!-- Local output folder on the build machine -->
    <PublishDir>bin\Release\net8.0-windows\app.publish\</PublishDir>

    <!-- Web model + updates -->
    <InstallFrom>Web</InstallFrom>
    <IsWebBootstrapper>True</IsWebBootstrapper>
    <UpdateEnabled>True</UpdateEnabled>
    <UpdateMode>Foreground</UpdateMode>
    <UpdateRequired>False</UpdateRequired>

    <!-- Must match your GitHub Pages path exactly -->
    <InstallUrl>https://insertnamehere1.github.io/SkyCal-CI-Test/published</InstallUrl>
    <UpdateUrl>https://insertnamehere1.github.io/SkyCal-CI-Test/published</UpdateUrl>

    <!-- Optional/cleanups -->
    <MapFileExtensions>True</MapFileExtensions>
    <SelfContained>False</SelfContained>
    <PublishReadyToRun>False</PublishReadyToRun>
    <PublishSingleFile>False</PublishSingleFile>
    <!-- Remove this to avoid confusion in SDK-style -->
    <!-- <PublishUrl>bin\publish\</PublishUrl> -->
  </PropertyGroup>
</Project>
